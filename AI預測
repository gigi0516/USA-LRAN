from sklearn.linear_model import LinearRegression

X = data[["Oil"]]
y = data["SP500"]

model = LinearRegression()
model.fit(X, y)

data["pred"] = model.predict(X)

plt.figure()
plt.plot(data["SP500"], label="Actual")
plt.plot(data["pred"], label="Predicted")
plt.legend()
plt.title("Prediction vs Actual")
plt.show()
